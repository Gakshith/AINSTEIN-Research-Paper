# Copy to .env and fill in. The pipeline's LLM stages call HuggingFace inference
# endpoints (deepseek-ai/DeepSeek-R1) and need an API token.
HUGGINGFACEHUB_API_TOKEN=

# Optional: surface bundled sample evaluation data on the dashboard when no real
# artifacts exist yet (great for a first look). Set to 1 to enable.
AINSTEIN_SAMPLE=0

# Optional: select a paper for the live demo without editing config/config.yaml.
# AINSTEIN_ROW_INDEX=0
# AINSTEIN_PAPER_ID=
